<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>10</LangVersion>
    <SuppressTfmSupportBuildWarnings>true</SuppressTfmSupportBuildWarnings>
    <NoWarn>$(NoWarn);CS9057</NoWarn>
    
    <!-- Asegurar que las librerías NuGet (Whisper.net, etc) se copien a la carpeta del mod -->
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>

    <!-- SMAPI configuración -->
    <EnableModZip>true</EnableModZip>
    <EnableModDeploy>true</EnableModDeploy>
  </PropertyGroup>


  <ItemGroup>
    <PackageReference Include="NAudio" Version="2.3.0" />
    <PackageReference Include="Pathoschild.Stardew.ModBuildConfig" Version="4.1.1" />
    <PackageReference Include="Whisper.net" Version="1.8.1" />
    <PackageReference Include="Whisper.net.Runtime" Version="1.8.1" />
    <!-- Forzar versiones .NET 6.0 para evitar conflictos de Assembly con SMAPI en SDKs modernos (ej. .NET 10) -->
    <PackageReference Include="System.Text.Json" Version="6.0.0" />
    <PackageReference Include="System.Text.Encodings.Web" Version="6.0.0" />
  </ItemGroup>

  <Target Name="CopyNativeWhisper" AfterTargets="Build">
    <ItemGroup>
      <!-- Windows x64 - el único que necesitas -->
      <NativeWin Include="$(NuGetPackageRoot)whisper.net.runtime\1.8.1\runtimes\win-x64\native\whisper.dll" />
    </ItemGroup>

    <!-- Copia whisper.dll al output -->
    <Copy
      SourceFiles="@(NativeWin)"
      DestinationFolder="$(OutputPath)"
      SkipUnchangedFiles="true"
      Condition="Exists('@(NativeWin)')" />

    <!-- Elimina ggml-metal.metal si quedó copiado por error -->
    <Delete Files="$(OutputPath)ggml-metal.metal" Condition="Exists('$(OutputPath)ggml-metal.metal')" />

    <Message Text="✅ whisper.dll nativo (win-x64) copiado correctamente" Importance="high" />
  </Target>

</Project>
